# Copy to .env and adjust for local Docker Compose overrides.
# Production Azure uses managed PostgreSQL 17 (see infra/), not the compose postgres service.

# PostgreSQL (compose postgres service)
POSTGRES_DB=newsagg
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Backend API host port (maps to container :8080)
BACKEND_PORT=5000

# Frontend host port (maps to container :80)
FRONTEND_PORT=3000

# Scheduled scraper (compose scraper service)
SCRAPE_INTERVAL_MINUTES=30
SCRAPE_EXTRACT_CONTENT=1
