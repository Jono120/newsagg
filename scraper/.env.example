# Backend API Configuration
# For local development, use http://localhost:5000
# For Docker deployment, use http://backend:8080
API_BASE_URL=http://localhost:5000
API_ARTICLES_ENDPOINT=/api/articles

# Scraper Configuration
SCRAPE_INTERVAL_MINUTES=30

# Content Extraction
SCRAPE_EXTRACT_CONTENT=1

# Text Analytics / Sentiment Provider
# Selects the analyzer backend: azure | huggingface | rules
ANALYZER_PROVIDER=azure

# Azure AI Language (Text Analytics) - used when ANALYZER_PROVIDER=azure
AZURE_LANGUAGE_ENDPOINT=https://your-language-resource.cognitiveservices.azure.com/
AZURE_LANGUAGE_KEY=your_azure_language_key_here

# Sentiment Analysis & Key Terms (HuggingFace fallback)
HF_SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest
HF_EXTRACTION_MODEL=ml6team/keyphrase-extraction-kbir-inspec

# HuggingFace API Token (required when ANALYZER_PROVIDER=huggingface)
HF_TOKEN=your_huggingface_token_here

# Sentiment Analysis Thresholds
HF_DOC_SENTIMENT_CONFIDENCE_MIN=0.55
HF_WORD_SENTIMENT_CONFIDENCE_MIN=0.65
HF_TERM_SIGNAL_MIN_TOTAL=3
HF_TERM_SIGNAL_BALANCE_DELTA=1
