# Backend API Configuration
# For local development, use http://localhost:5000
# For Docker deployment, use http://backend:8080
API_BASE_URL=http://localhost:5000
API_ARTICLES_ENDPOINT=/api/articles

# Scraper Configuration
SCRAPE_INTERVAL_MINUTES=30

# Content Extraction
SCRAPE_EXTRACT_CONTENT=1

# Sentiment Analysis & Key Terms
HF_SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest
HF_EXTRACTION_MODEL=ml6team/keyphrase-extraction-kbir-inspec

# HuggingFace API Token (required for sentiment analysis)
HF_TOKEN=your_huggingface_token_here

# Sentiment Analysis Thresholds
HF_DOC_SENTIMENT_CONFIDENCE_MIN=0.55
HF_WORD_SENTIMENT_CONFIDENCE_MIN=0.65
HF_TERM_SIGNAL_MIN_TOTAL=3
HF_TERM_SIGNAL_BALANCE_DELTA=1
